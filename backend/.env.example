# Copy this file to .env and fill in your values
# Never commit .env to git!

# NASA API (get free key at https://api.nasa.gov/)
NASA_API_KEY=DEMO_KEY

# Google Cloud / Vertex AI (for Gemini agent swarm)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account key
# or use gcp_key.json (also excluded from git)
